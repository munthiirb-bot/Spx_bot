//+------------------------------------------------------------------+
//|  SPX500 Strategy - Support/Resistance + 100 EMA                  |
//|  Version: 1.0                                                     |
//|  Author: MiniMax Agent                                            |
//|                                                                  |
//|  STRATEGY RULES:                                                 |
//|  - SPX500 on 1H timeframe                                        |
//|  - Price near Support/Resistance + 100 EMA = Strong Reversal     |
//|  - Breakout + Close = Strong Direction                           |
//+------------------------------------------------------------------+

//@version=5
strategy("SPX500 S/R + 100 EMA Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// ============== INPUTS ==============

// Indicator Settings
emaLength     = input.int(100, "100 EMA Length", minval=1)
atrLength     = input.int(14, "ATR Length", minval=1)

// S/R Detection Settings
lookbackBars  = input.int(50, "Lookback for S/R", minval=10)
strengthThreshold = input.float(2.0, "Min Touches for S/R", minval=1)

// Alert Settings
emaProximity  = input.float(10.0, "EMA Proximity (points)", minval=1)
breakoutThreshold = input.float(5.0, "Breakout Confirmation (points)", minval=1)

// Enable/Disable
showEMALine   = input.bool(true, "Show 100 EMA")
showSRLines   = input.bool(true, "Show S/R Levels")
showLabels    = input.bool(true, "Show Labels")
enableAlerts  = input.bool(true, "Enable Alerts")

// ============== INDICATORS ==============

// 100 EMA
ema100 = ta.ema(close, emaLength)
plot(showEMALine ? ema100 : na, "100 EMA", color=color.orange, linewidth=2)

// ATR for context
atr = ta.atr(atrLength)

// ============== SUPPORT & RESISTANCE DETECTION ==============

// Find pivot highs and lows for S/R
pivothigh = ta.pivothigh(high, lookbackBars, lookbackBars)
pivotlow = ta.pivotlow(low, lookbackBars, lookbackBars)

// Track resistance levels (array approach)
var float[] resistanceLevels = array.new_float()
var float[] supportLevels = array.new_float()

// Add new resistance levels
if not na(pivothigh)
    array.push(resistanceLevels, pivothigh)
    if array.size(resistanceLevels) > 5
        array.shift(resistanceLevels)

// Add new support levels
if not na(pivotlow)
    array.push(supportLevels, pivotlow)
    if array.size(supportLevels) > 5
        array.shift(supportLevels)

// Find nearest S/R levels
nearestResistance = 0.0
nearestSupport = 0.0
emaDistanceRes = 0.0
emaDistanceSup = 0.0

// Calculate nearest resistance above price
for i = 0 to array.size(resistanceLevels) - 1
    level = array.get(resistanceLevels, i)
    if level > close and (nearestResistance == 0 or level < nearestResistance)
        nearestResistance := level
        emaDistanceRes := level - ema100

// Calculate nearest support below price
for i = 0 to array.size(supportLevels) - 1
    level = array.get(supportLevels, i)
    if level < close and (nearestSupport == 0 or level > nearestSupport)
        nearestSupport := level
        emaDistanceSup := ema100 - level

// ============== PLOT S/R LEVELS ==============

// Resistance Line
var line resistLine = na
if showSRLines and nearestResistance > 0
    line.delete(resistLine)
    resistLine := line.new(x=bar_index - lookbackBars, y=nearestResistance, x2=bar_index, y2=nearestResistance, color=color.red, width=2, style=line.style_dashed)

// Support Line
var line supportLine = na
if showSRLines and nearestSupport > 0
    line.delete(supportLine)
    supportLine := line.new(x=bar_index - lookbackBars, y=nearestSupport, x2=bar_index, y2=nearestSupport, color=color.green, width=2, style=line.style_dashed)

// ============== SIGNAL DETECTION ==============

// Condition 1: Price near Resistance + close to EMA = Bearish Reversal
nearResistanceAndEMA = nearestResistance > 0 and (close >= nearestResistance - emaProximity) and (ema100 >= nearestResistance - emaProximity * 2)

// Condition 2: Price near Support + close to EMA = Bullish Reversal
nearSupportAndEMA = nearestSupport > 0 and (close <= nearestSupport + emaProximity) and (ema100 <= nearestSupport + emaProximity * 2)

// Condition 3: Breakout above resistance with close
resistanceBreakout = nearestResistance > 0 and close > nearestResistance + breakoutThreshold and close > open

// Condition 4: Breakout below support with close
supportBreakout = nearestSupport > 0 and close < nearestSupport - breakoutThreshold and close < open

// ============== PLOT SIGNALS ==============

// Reversal Signals (circles)
plotshape(showLabels and nearResistanceAndEMA and close < open, "Bearish Reversal", shape.circle, location.abovebar, color.red, size=size.large, text="📍")
plotshape(showLabels and nearSupportAndEMA and close > open, "Bullish Reversal", shape.circle, location.belowbar, color.green, size=size.large, text="📍")

// Breakout Signals (arrows)
plotshape(showLabels and resistanceBreakout, "Bull Breakout", shape.arrowup, location.abovebar, color.blue, size=size.large)
plotshape(showLabels and supportBreakout, "Bear Breakout", shape.arrowdown, location.belowbar, color.purple, size=size.large)

// ============== ALERT MESSAGES ==============

// Bearish Reversal Alert
if enableAlerts and nearResistanceAndEMA and close < open
    alert(
     "🔴 BEARISH REVERSAL SIGNAL\n" +
     "📍 SPX500 1H\n" +
     "💰 Price: " + str.tostring(close, format.mintick) + "\n" +
     "📊 Resistance: " + str.tostring(nearestResistance, format.mintick) + "\n" +
     "📏 EMA Distance: " + str.tostring(emaDistanceRes, format.mintick) + "\n" +
     "💪 Recommendation: PUT",
     alert.freq_once_per_bar
    )

// Bullish Reversal Alert
if enableAlerts and nearSupportAndEMA and close > open
    alert(
     "🟢 BULLISH REVERSAL SIGNAL\n" +
     "📍 SPX500 1H\n" +
     "💰 Price: " + str.tostring(close, format.mintick) + "\n" +
     "📊 Support: " + str.tostring(nearestSupport, format.mintick) + "\n" +
     "📏 EMA Distance: " + str.tostring(emaDistanceSup, format.mintick) + "\n" +
     "💪 Recommendation: CALL",
     alert.freq_once_per_bar
    )

// Bullish Breakout Alert
if enableAlerts and resistanceBreakout
    alert(
     "⬆️ BULLISH BREAKOUT\n" +
     "📍 SPX500 1H\n" +
     "💰 Price: " + str.tostring(close, format.mintick) + "\n" +
     "📊 Resistance Broken: " + str.tostring(nearestResistance, format.mintick) + "\n" +
     "📏 Breakout: " + str.tostring(close - nearestResistance, format.mintick) + "\n" +
     "💪 Recommendation: CALL",
     alert.freq_once_per_bar
    )

// Bearish Breakout Alert
if enableAlerts and supportBreakout
    alert(
     "⬇️ BEARISH BREAKOUT\n" +
     "📍 SPX500 1H\n" +
     "💰 Price: " + str.tostring(close, format.mintick) + "\n" +
     "📊 Support Broken: " + str.tostring(nearestSupport, format.mintick) + "\n" +
     "📏 Breakdown: " + str.tostring(nearestSupport - close, format.mintick) + "\n" +
     "💪 Recommendation: PUT",
     alert.freq_once_per_bar
    )

// ============== INFO TABLE ==============

var table infoTable = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 90))

if barstate.islast
    table.cell(infoTable, 0, 0, "Strategy Info", text_color=color.white)
    table.cell(infoTable, 1, 0, "", text_color=color.white)

    table.cell(infoTable, 0, 1, "EMA (100)", text_color=color.orange)
    table.cell(infoTable, 1, 1, str.tostring(ema100, format.mintick), text_color=color.orange)

    table.cell(infoTable, 0, 2, "Nearest R", text_color=color.red)
    table.cell(infoTable, 1, 2, str.tostring(nearestResistance, format.mintick), text_color=color.red)

    table.cell(infoTable, 0, 3, "Nearest S", text_color=color.green)
    table.cell(infoTable, 1, 3, str.tostring(nearestSupport, format.mintick), text_color=color.green)

    table.cell(infoTable, 0, 4, "Signal", text_color=color.white)
    signalText = resistanceBreakout ? "⬆️ BREAKOUT" :
                 supportBreakout ? "⬇️ BREAKOUT" :
                 nearResistanceAndEMA ? "📍 NEAR RES" :
                 nearSupportAndEMA ? "📍 NEAR SUP" : "➡️ NEUTRAL"
    table.cell(infoTable, 1, 4, signalText, text_color=color.yellow)

// ============== WEBHOOK DATA FOR ALERTS ==============

// To use with Telegram bot, set alert message to:
// {{strategy.order.alert_message}}

// Or use Webhook URL in alert with this JSON format:
// {"signal_type": "REVERSAL_BEARISH", "price": {{close}}, "level": {{nearestResistance}}, "level_type": "RESISTANCE", "ema_distance": {{emaDistanceRes}}, "strength": "STRONG", "time": "{{time}}"}

// Note: For actual webhook, you need to create custom alerts with webhook URL pointing to your Python bot
// The Pine Script alerts are set to fire once per bar